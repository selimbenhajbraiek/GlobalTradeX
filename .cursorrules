schemas/ <- Pydantic schemas: user.py, shipment.py ...
routers/ <- auth.py, users.py, shipments.py, products.py,
documents.py, calculator.py, analytics.py, ai.py
auth/ <- hashing.py, jwt.py, dependencies.py
services/ <- openai_service.py, did_service.py,
elevenlabs_service.py, email_service.py
