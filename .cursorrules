login/page.jsx <- login form
register/page.jsx <- register with role selection
dashboard/
layout.jsx <- Sidebar + Header wrapper
page.jsx <- smart redirect by role
admin/page.jsx
importateur/page.jsx
exportateur/page.jsx
transitaire/page.jsx
