@startuml GlobalTradeX_UseCase_Global
' Diagramme de cas d'utilisation global — GlobalTradeX
' Structure : hiérarchie d'acteurs (gauche) + frontière système + S'authentifier + Assistant IA

left to right direction
skinparam shadowing false
skinparam nodesep 14
skinparam ranksep 10
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #E8F5E9
  BorderColor #2E7D32
  FontSize 10
}
skinparam actor {
  FontSize 10
}
skinparam arrow {
  Color #1565C0
}

title Figure 2.1 - Diagramme de cas d'utilisation global (GlobalTradeX)

' —— Acteurs (hiérarchie comme le modèle SmartChain / U.C. Générale) ——
actor "Internaute" as guest
actor "Utilisateur\nauthentifié" as user
actor "Importateur" as imp
actor "Exportateur" as exp
actor "Transitaire" as fwd
actor "Courtier en\ndouane" as brk
actor "Administrateur" as adm
actor "Assistant IA\n(TradeFlow)" as ai #E3F2FD

guest <|-- user
user <|-- imp
user <|-- exp
user <|-- fwd
user <|-- brk
user <|-- adm

usecase "S'authentifier" as UC_AUTH #BBDEFB

rectangle "GlobalTradeX" {

  together {
    usecase "S'inscrire" as UC_REG
    usecase "Consulter\nvitrine" as UC_LANDING
    usecase "Récupérer\nmot de passe" as UC_FORGOT
    usecase "Vérifier\nadresse e-mail" as UC_VERIFY
  }

  together {
    usecase "Gérer profil" as UC_PROFILE
    usecase "Consulter\nnotifications" as UC_NOTIF
    usecase "Messagerie" as UC_MSG
    usecase "Gérer préférences\nnotifications" as UC_PREFS
    usecase "Suivi GPS\nen direct" as UC_GPS
    usecase "Procurer aide" as UC_HELP
  }

  together {
    usecase "Créer\nexpédition" as UC_IMP_CREATE
    usecase "Suivre\nexpéditions" as UC_IMP_TRACK
    usecase "Optimiser\nitinéraire" as UC_IMP_ROUTE
    usecase "Consulter\ndocuments" as UC_IMP_DOCS
  }

  together {
    usecase "Gérer produits" as UC_EXP_PROD
    usecase "Créer expédition\n(sortante)" as UC_EXP_CREATE
    usecase "Téléverser docs\ncommerciaux" as UC_EXP_UPLOAD
  }

  together {
    usecase "Mettre à jour\nstatut" as UC_FWD_STATUS
    usecase "Enrichir\ntransport" as UC_FWD_TRANSPORT
    usecase "Téléverser\nB/L" as UC_FWD_BL
  }

  together {
    usecase "File de revue\ndocuments" as UC_BRK_QUEUE
    usecase "Vérifier doc.\n(IA)" as UC_BRK_AI
    usecase "Valider /\nrejeter" as UC_BRK_DECIDE
  }

  together {
    usecase "Analytics\nglobale" as UC_ADM_ANALYTICS
    usecase "Gérer\nutilisateurs" as UC_ADM_USERS
    usecase "Configurer\nassistant" as UC_ADM_ASSISTANT
    usecase "Toutes\nexpéditions" as UC_ADM_SHIP
  }
}

' —— Associations acteur → cas d'utilisation ——
guest --> UC_REG
guest --> UC_LANDING
guest --> UC_FORGOT
guest --> UC_VERIFY

user --> UC_PROFILE
user --> UC_NOTIF
user --> UC_MSG
user --> UC_PREFS
user --> UC_GPS
user --> UC_HELP

imp --> UC_IMP_CREATE
imp --> UC_IMP_TRACK
imp --> UC_IMP_ROUTE
imp --> UC_IMP_DOCS

exp --> UC_EXP_PROD
exp --> UC_EXP_CREATE
exp --> UC_EXP_UPLOAD
exp --> UC_IMP_TRACK
exp --> UC_IMP_DOCS

fwd --> UC_FWD_STATUS
fwd --> UC_FWD_TRANSPORT
fwd --> UC_FWD_BL
fwd --> UC_IMP_TRACK

brk --> UC_BRK_QUEUE
brk --> UC_BRK_AI
brk --> UC_BRK_DECIDE

adm --> UC_ADM_ANALYTICS
adm --> UC_ADM_USERS
adm --> UC_ADM_ASSISTANT
adm --> UC_ADM_SHIP
adm --> UC_IMP_TRACK
adm --> UC_BRK_QUEUE

' —— Assistant IA (équivalent ChatBot) ——
UC_HELP ..> ai : <<communicate>>
UC_BRK_AI ..> ai : <<communicate>>

' —— Include : authentification obligatoire ——
UC_PROFILE ..> UC_AUTH : <<include>>
UC_NOTIF ..> UC_AUTH : <<include>>
UC_MSG ..> UC_AUTH : <<include>>
UC_PREFS ..> UC_AUTH : <<include>>
UC_GPS ..> UC_AUTH : <<include>>
UC_HELP ..> UC_AUTH : <<include>>
UC_IMP_CREATE ..> UC_AUTH : <<include>>
UC_IMP_TRACK ..> UC_AUTH : <<include>>
UC_IMP_ROUTE ..> UC_AUTH : <<include>>
UC_IMP_DOCS ..> UC_AUTH : <<include>>
UC_EXP_PROD ..> UC_AUTH : <<include>>
UC_EXP_CREATE ..> UC_AUTH : <<include>>
UC_EXP_UPLOAD ..> UC_AUTH : <<include>>
UC_FWD_STATUS ..> UC_AUTH : <<include>>
UC_FWD_TRANSPORT ..> UC_AUTH : <<include>>
UC_FWD_BL ..> UC_AUTH : <<include>>
UC_BRK_QUEUE ..> UC_AUTH : <<include>>
UC_BRK_AI ..> UC_AUTH : <<include>>
UC_BRK_DECIDE ..> UC_AUTH : <<include>>
UC_ADM_ANALYTICS ..> UC_AUTH : <<include>>
UC_ADM_USERS ..> UC_AUTH : <<include>>
UC_ADM_ASSISTANT ..> UC_AUTH : <<include>>
UC_ADM_SHIP ..> UC_AUTH : <<include>>

@enduml
